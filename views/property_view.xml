<odoo>

    <record id="property_action" model="ir.actions.act_window">
        <field name="name">All Properties</field>
        <field name="res_model">property</field>
    </record>

    <!--    <record id="property_closed_action" model="ir.actions.server">-->
    <!--        <field name="name">Closed</field>-->
    <!--        <field name="model_id" ref="model_property"/>-->
    <!--        <field name="binding_model_id" ref="model_property"/>-->
    <!--        <field name="state">code</field>-->
    <!--        <field name="code">-->
    <!--            action = records.action_closed()-->
    <!--        </field>-->
    <!--    </record>-->


            <record id="change_state_action" model="ir.actions.server">
            <field name="name">Change State</field>
            <field name="model_id" ref="model_property"/>
            <field name="binding_model_id" ref="model_property"/>
            <field name="state">code</field>
            <field name="code">
                action = records.open_change_state_wizard()
            </field>
        </record>

    <record id="check_selling_cron" model="ir.cron">
        <field name="name">Property Checking Selling</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">model.check_expected_selling_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>

    <menuitem
            id="property_item"
            name="All Properties"
            parent="property_menu"
            action="property_action"
    />


    <record id="property_view_tree" model="ir.ui.view">
        <field name="name">property tree</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <tree multi_edit="1" class="table_style" decoration-danger="(is_late)">
                <!--            <tree multi_edit="1" edit="0" create="0" delete="0">-->
                <field name="name"/>
                <field name="owner_id"/>
                <field name="description"/>
                <field name="tag_ids"/>
                <field name="postcode"/>
                <field name="is_late" />
                <field name="date_availability"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="state"/>
                <field name="bedrooms" optional="1"/>
                <field name="living_area" optional="1"/>
                <field name="garage"/>
                <field name="garden"/>
                <field name="garden_area"/>
                <field name="garden_orientation"/>
            </tree>
        </field>
    </record>

    <record id="property_view_form" model="ir.ui.view">
        <field name="name">property form</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div style="display: flex; justify-content: space-between; align-items:center">
                        <div>
                            <button name="set_to_draft" type="object" class="btn-primary mx-1" string="Set To Draft"
                                    invisible="state in ('draft','closed')"/>
                            <button name="set_to_pending" type="object" class="btn-secondary mx-3" string="Pending"
                                    invisible="state != 'draft'"/>
                            <button name="set_to_sold" type="object" class="btn-success" string="Sold"
                                    invisible="state != 'pending'"/>
                        </div>
                        <div>
                            <field name="state" widget="statusbar" options="{'clickable': 1}"/>
                        </div>
                    </div>

                    <div class="oe_title mt-5">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>
                        <label for="name"/>
                        <h3>
                            <field name="name" readonly="state == 'closed'"/>
                        </h3>
                    </div>

                    <group>
                        <group string="general info.">
                            <field name="owner_id" readonly="state == 'closed'"/>
                            <field name="owner_phone" readonly="state == 'closed'"/>
                            <field name="owner_address" readonly="state == 'closed'"/>
                            <field name="postcode" readonly="state == 'closed'"/>
                            <field name="date_availability" readonly="state == 'closed'"/>
                            <field name="expected_selling_date" readonly="state == 'closed'"/>
                            <field name="is_late" invisible="1" readonly="state == 'closed'"/>
                            <field name="expected_price" readonly="state == 'closed'"/>
                            <field name="selling_price" readonly="state == 'closed'"/>
                            <field name="diff" readonly="state == 'closed'"/>
                            <field name="tag_ids" widget="many2many_tags" readonly="state == 'closed'"/>
                        </group>

                        <group string="additional info.">
                            <field name="bedrooms" readonly="state == 'closed'"/>
                            <field name="living_area" readonly="state == 'closed'"/>
                            <field name="garage" readonly="state == 'closed'"/>
                            <field name="garden" readonly="state == 'closed'"/>
                            <field name="garden_area" readonly="state == 'closed'"/>
                            <field name="garden_orientation" readonly="state == 'closed'"/>
                            <field name="active" readonly="state == 'closed'"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" readonly="state == 'closed'"/>
                    </group>
                    <notebook>
                        <page string="bedrooms">
                            <field name="line_ids" readonly="state == 'closed'">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="area"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="property_view_search" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <field name="postcode"/>
                <field name="name"/>
                <filter name="garden" string="With Garden" domain="[('garden','=',True)]"/>
                <filter name="garden" string="Without Garden" domain="[('garden','=',False)]"/>
                <filter name="garden" string="Garden" context="{'group_by':'garden'}"/>
            </search>
        </field>
    </record>
</odoo>